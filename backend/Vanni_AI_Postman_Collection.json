    {
      "name": "7. Voice",
      "item": [
        {
          "name": "STT (Speech to Text)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/voice/stt",
              "host": ["{{base_url}}"],
              "path": ["voice", "stt"]
            }
          }
        },
        {
          "name": "TTS (Text to Speech)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Hello, how are you doing today?\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/voice/tts",
              "host": ["{{base_url}}"],
              "path": ["voice", "tts"]
            }
          }
        },
        {
          "name": "Voice Conversation (REST)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
