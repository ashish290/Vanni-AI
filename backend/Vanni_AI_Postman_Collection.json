                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"What is a noun?\",\n  \"conversationId\": \"add-conversation-id-here\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/voice/conversation",
              "host": ["{{base_url}}"],
              "path": ["voice", "conversation"]
            }
          }
        }
      ]
    }
  ]
}
